{
  "version": 2,
  "buildCommand": "cd frontend && npm install && npm run build",
  "outputDirectory": "frontend/dist",
  "functions": {
    "api/index.js": {
      "memory": 512,
      "maxDuration": 30,
      "includeFiles": "backend/src/**,node_modules/sql.js/dist/sql-wasm.wasm"
    }
  },
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/index.js" },
    { "src": "/assets/(.*)", "dest": "/frontend/dist/assets/$1" },
    { "src": "/static/(.*)", "dest": "/frontend/dist/static/$1" },
    { "src": "/(.*)\\.(css|js|map|png|jpg|jpeg|gif|svg|ico|webp|woff|woff2|ttf|eot)$", "dest": "/frontend/dist/$1.$2" },
    { "src": "/(.*)", "dest": "/frontend/dist/index.html" }
  ]
}